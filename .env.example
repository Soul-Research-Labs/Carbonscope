# CarbonScope environment configuration
# Copy to .env and fill in real values for production

# Environment: development | production | test
ENV=development

SECRET_KEY=change-me-to-a-random-64-char-string
DATABASE_URL=sqlite+aiosqlite:///./carbonscope.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/carbonscope
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_DEFAULT=60/minute
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Estimation: local (dev) or subnet (production Bittensor)
ESTIMATION_MODE=local

# Bittensor (optional — used when ESTIMATION_MODE=subnet)
BT_NETWORK=test
BT_NETUID=1
BT_WALLET_NAME=api_client
BT_WALLET_HOTKEY=default
BT_QUERY_TIMEOUT=30.0

# Email / SMTP (optional — logs emails if not configured)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# EMAIL_FROM=noreply@carbonscope.io

# Stripe (optional — for subscription billing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
